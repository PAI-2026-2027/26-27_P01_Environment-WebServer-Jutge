# ---------------------------------------------------------------------------
# Linux
# ---------------------------------------------------------------------------
*~

# ---------------------------------------------------------------------------
# Dependencies (Never commit node_modules)
# ---------------------------------------------------------------------------
node_modules/
jspm_packages/
web_modules/

# ---------------------------------------------------------------------------
# Build & Transpilation Outputs
# ---------------------------------------------------------------------------
# Standard TS/JS build directories
dist/
build/
out/
lib/

# TypeScript incremental build cache
*.tsbuildinfo

# Next.js, Nuxt.js, Gatsby, Remix outputs
.next/
.nuxt/
.gatsby/
.remix/
.cache/

# ---------------------------------------------------------------------------
# Environment Variables & Secrets (CRITICAL SECURITY)
# ---------------------------------------------------------------------------
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
*.env.json

# ---------------------------------------------------------------------------
# Logs, Diagnostic Tests, and Traces
# ---------------------------------------------------------------------------
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
.pnpm-debug.log*

# Runtime data
pids
*.pid
*.seed
*.pid.lock

# ---------------------------------------------------------------------------
# Testing & Coverage Outputs
# ---------------------------------------------------------------------------
coverage/
.nyc_output/
.jest/
.mocha/
.cypress/
*.lcov

# ---------------------------------------------------------------------------
# IDEs, Text Editors, and System Files
# ---------------------------------------------------------------------------
# Editor-specific configurations
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.swp

# OS generated files
.DS_Store
Thumbs.db
